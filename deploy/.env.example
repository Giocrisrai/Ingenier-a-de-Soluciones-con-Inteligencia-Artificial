# deploy/.env.example — Variables del despliegue (NO poner secretos reales aquí).
# Copia a deploy/.env y completa en la máquina destino:  cp deploy/.env.example deploy/.env

# --- GitHub Models (mismo proveedor que el resto del curso) ---
GITHUB_TOKEN=""
OPENAI_BASE_URL="https://models.inference.ai.azure.com"
AGENT_MODEL="gpt-4o-mini"

# --- Observabilidad (opcional, reusa RA3.1/3.2) ---
LANGSMITH_TRACING="false"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="ingenieria_soluciones_con_ia"

# --- URL interna del backend que usa el frontend (red docker) ---
BACKEND_URL="http://backend:8000"

# --- Dominio para Caddy: usa la IP pública de la EC2 o un dominio.
# Con una IP, Caddy emite un certificado self-signed (el navegador avisará).
SITE_ADDRESS=":443"
