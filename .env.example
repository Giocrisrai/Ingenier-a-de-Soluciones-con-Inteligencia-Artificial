# ===========================================
# Variables de Entorno - Curso IA
# ===========================================
# Copia este archivo como .env y completa con tus credenciales:
#   cp .env.example .env
# Docker Compose exige que exista `.env` en la raíz (puede tener valores vacíos si solo abres Jupyter).
#
# IMPORTANTE: Nunca subas el archivo .env al repositorio

# --- GitHub Models API ---
# URLs base para acceder a los modelos de GitHub (no modificar)
OPENAI_BASE_URL="https://models.inference.ai.azure.com"
GITHUB_BASE_URL="https://models.inference.ai.azure.com"
OPENAI_EMBEDDINGS_URL="https://models.github.ai/inference"

# Tu token personal de GitHub con acceso a GitHub Models
# Obtener en: https://github.com/settings/tokens
GITHUB_TOKEN=""

# OPENAI_API_KEY se configura automáticamente desde GITHUB_TOKEN en los notebooks
# (langchain_openai requiere esta variable para el cliente AsyncOpenAI interno)
# OPENAI_API_KEY="${GITHUB_TOKEN}"

# Modelo por defecto para agentes
AGENT_MODEL="gpt-4o-mini"

# Los nombres de modelo del Streamlit RA1/IL1.4/1-evaluation-rag.py están definidos
# en constantes al inicio de ese archivo (MODELO_CHAT, MODELO_EMBEDDINGS) para el curso.

# --- LangSmith (Observabilidad) ---
# Habilitar trazabilidad con LangSmith
LANGSMITH_TRACING="true"

# Tu API key de LangSmith
# Obtener en: https://smith.langchain.com/ > Settings > API Keys
LANGSMITH_API_KEY=""

# Nombre del proyecto en LangSmith
LANGSMITH_PROJECT="ingenieria_soluciones_con_ia"
